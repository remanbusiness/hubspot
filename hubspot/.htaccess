RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Remove .php extension from URL
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php [NC]
RewriteRule ^ /hubspot/%1 [R=301,L]

# Internally map clean URL to PHP file
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# Handle API routes like /contacts or /companies
RewriteRule ^(contacts|companies)$ handleApi.php?type=$1 [L,QSA]

# OPTIONAL: allow dynamic types (uncomment if needed)
# RewriteRule ^([a-zA-Z0-9_-]+)$ handleApi.php?type=$1 [L,QSA]